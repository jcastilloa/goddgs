{
  "contract": {
    "category": "images",
    "engine": "duckduckgo",
    "kind": "engine",
    "operation": "search"
  },
  "controls": {
    "clock": "not used",
    "notes": [
      "all HTTP responses are synthetic"
    ],
    "random": "not used"
  },
  "fixture_id": "engine.images.duckduckgo-happy-json",
