      "kind": "request",
      "method": "GET",
      "query": {
        "InfiniteScroll": "1",
        "SFX": "2",
        "cc": "de",
        "first": "21",
        "q": "fixture bing news",
        "qft": "interval=\"4\"",
        "setlang": "de"
      },
      "sequence": 1,
      "url": "https://www.bing.com/news/infinitescrollajax"
