{
  "contract": {
    "category": "news",
    "engine": "yahoo",
    "kind": "engine",
    "operation": "search"
  },
  "controls": {
    "clock": "not used",
    "notes": [
      "relative-date clock behavior is covered separately; this case uses a non-date lexical value"
    ],
    "random": "not used"
  },
  "fixture_id": "engine.news.yahoo-happy-html-postprocess",
  "input": {
    "page": 2,
    "query": "fixture yahoo news",
    "region": "us-en",
    "safesearch": "off",
    "timelimit": "m"
  },
  "redaction": {
    "rules": [
      "synthetic inputs and responses",
      "no external request",
      "no credentials or live session cookies"
    ],
    "sanitized": true
  },
  "result": {
    "field_order": [
      [
        "date",
        "title",
        "body",
        "url",
        "image",
        "source"
      ]
    ],
    "output": [
      {
        "body": "Fixture body",
        "date": "fixture date",
        "image": "fixture.jpg",
        "source": "Fixture source · via Yahoo",
        "title": "Fixture Yahoo News",
        "url": "https://yahoo-news.example/a"
      }
    ],
    "status": "ok"
  },
  "schema_version": 1,
  "source": {
    "commit": "a12929a72429a39a0841c3d7caacb20ee17acd4d",
