      "brotli": "1.2.0",
      "certifi": "2026.6.17",
      "click": "8.4.2",
      "ddgs": "9.14.4",
      "fake-useragent": "2.2.0",
      "h11": "0.16.0",
      "h2": "4.3.0",
      "hpack": "4.2.0",
      "httpcore": "1.0.9",
      "httpx": "0.28.1",
      "hyperframe": "6.1.0",
      "idna": "3.18",
      "lxml": "6.1.1",
      "primp": "1.3.1",
      "socksio": "1.0.0",
      "typing-extensions": "4.16.0"
    }
  },
