{
  "contract": {
    "category": "text",
    "engine": "google",
    "kind": "engine",
    "operation": "search"
  },
  "controls": {
    "clock": "not used",
    "notes": [
      "Google module-lifetime randomized User-Agent is redacted to a stable marker"
    ],
    "random": "not used"
  },
  "fixture_id": "engine.text.google-consent-and-redirect-filter",
