{
  "contract": {
    "category": "text",
    "engine": "yahoo",
    "kind": "engine",
    "operation": "search"
  },
  "controls": {
    "clock": "not used",
    "random": "token_urlsafe patched to deterministic synthetic values per source search"
  },
  "fixture_id": "engine.text.yahoo-random-path-and-redirect-unwrapping",
  "input": {
    "page": 3,
    "query": "fixture yahoo",
    "region": "us-en",
    "safesearch": "moderate",
    "timelimit": "y"
  },
  "redaction": {
    "rules": [
      "synthetic inputs and responses",
      "no external request",
      "no credentials or live session cookies"
    ],
    "sanitized": true
  },
  "result": {
    "field_order": [
      [
        "title",
        "href",
        "body"
      ]
    ],
    "output": {
      "results": [
        {
          "body": "Yahoo body",
          "href": "https://target.example/path?a=1+two",
          "title": "Yahoo fixture"
        }
      ],
      "search_url": "https://search.yahoo.com/search;_ylt=synthetic-token-18;_ylu=synthetic-token-35"
    },
    "status": "ok"
  },
  "schema_version": 1,
  "source": {
    "commit": "a12929a72429a39a0841c3d7caacb20ee17acd4d",
    "package_version": "9.14.4",
    "python": "3.12.3",
    "reference_environment": "docs/reference-environment.md",
    "resolved_packages": {
      "anyio": "4.14.2",
      "brotli": "1.2.0",
      "certifi": "2026.6.17",
      "click": "8.4.2",
      "ddgs": "9.14.4",
      "fake-useragent": "2.2.0",
      "h11": "0.16.0",
      "h2": "4.3.0",
      "hpack": "4.2.0",
      "httpcore": "1.0.9",
      "httpx": "0.28.1",
      "hyperframe": "6.1.0",
      "idna": "3.18",
      "lxml": "6.1.1",
      "primp": "1.3.1",
      "socksio": "1.0.0",
      "typing-extensions": "4.16.0"
    }
  },
  "trace": [
    {
      "kind": "random",
      "sequence": 1,
      "value": {
        "function": "token_urlsafe",
        "nbytes": 18,
        "value": "synthetic-token-18"
      }
    },
    {
      "kind": "random",
      "sequence": 2,
      "value": {
        "function": "token_urlsafe",
        "nbytes": 35,
        "value": "synthetic-token-35"
      }
    },
    {
      "kind": "request",
      "method": "GET",
      "query": {
        "b": "15",
        "btf": "y",
        "p": "fixture yahoo"
      },
      "sequence": 3,
      "url": "https://search.yahoo.com/search;_ylt=synthetic-token-18;_ylu=synthetic-token-35"
    },
    {
      "content_hex": "",
      "kind": "response",
      "sequence": 4,
      "status": 200,
      "text": "\n    <html><body><div class=\"relsrch\">\n      <div class=\"Title\"><a href=\"https://r.search.yahoo.com/_ylt=x/RU=https%3A%2F%2Ftarget.example%2Fpath%3Fa%3D1%2Btwo/RK=fixture\"><h3>Yahoo fixture</h3></a></div>\n      <div class=\"Text\">Yahoo body</div>\n    </div></body></html>\n    "
    }
  ]
}
